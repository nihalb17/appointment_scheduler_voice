# ============================================
# Multi-Agent Appointment Scheduler — .env
# ============================================

# ------ LLM: Groq (Orchestrator Agent) ------
GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GROQ_FALLBACK_API_KEY=
GROQ_FALLBACK_MODEL_NAME=llama-3.3-70b-versatile

# ------ LLM: Gemini — Eligibility Agent ------
GEMINI_ELIGIBILITY_API_KEY=
GEMINI_ELIGIBILITY_MODEL_NAME=gemini-2.5-flash
GEMINI_ELIGIBILITY_FALLBACK_API_KEY=
GEMINI_ELIGIBILITY_FALLBACK_MODEL_NAME=gemini-2.5-flash

# ------ LLM: Gemini — Booking & Cancellation Agents ------
GEMINI_ACTIONS_API_KEY=
GEMINI_ACTIONS_MODEL_NAME=gemini-2.5-flash
GEMINI_ACTIONS_FALLBACK_API_KEY=
GEMINI_ACTIONS_FALLBACK_MODEL_NAME=gemini-2.5-flash

# ------ Google OAuth 2.0 (shared by all MCP tools) ------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ------ MCP: Google Calendar ------
GOOGLE_CALENDAR_ID=

# ------ MCP: Google Docs ------
GOOGLE_DOCS_FOLDER_ID=

# ------ MCP: Gmail ------
MF_DISTRIBUTOR_EMAIL=

# ------ MCP: Google Sheets ------
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Meetings_Log

# ------ Knowledge Base ------
KNOWLEDGE_BASE_PATH=./knowledge_base

# ------ Voice Agent (Phase 6) — Sarvam AI ------
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_VOICE_ID=ritu
SARVAM_LANGUAGE=en-IN

# ------ Voice Agent (Phase 6) — Audio ------
AUDIO_SAMPLE_RATE=16000
AUDIO_ENCODING=linear16
AUDIO_CHANNELS=1

# ------ Chat Frontend (Phase 7) ------
# Local development:
BACKEND_API_URL=http://localhost:8020
FRONTEND_PORT=5174

# Production (Set on Vercel):
# VITE_API_URL=https://your-backend.onrender.com

# ------ Internal Dashboard (/internal) ------
INTERNAL_DASHBOARD_URL=http://localhost:8020/internal
KNOWLEDGE_BASE_MAX_FILE_SIZE_MB=10
KNOWLEDGE_BASE_ALLOWED_EXTENSIONS=.pdf,.csv,.xlsx,.docx,.txt
